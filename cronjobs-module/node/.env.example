# Copy to `.env`. All values are optional — defaults work for local use.

# Folder where your twin lives (CLAUDE.md / persona). Default: this folder.
# TWIN_DIR=/absolute/path/to/your-twin

# Where scheduled jobs are stored. Default: ./data/jobs.json
# JOBS_FILE=./data/jobs.json

# How often to check for due jobs, in ms. Default: 30000 (30s).
# POLL_MS=30000

# Optional Slack delivery. If both are set, fired jobs are also posted to Slack.
# Reuse the bot token from your Slack module. Channel = a channel ID (e.g. C0123)
# or your own user ID for a DM.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=C0123ABC
